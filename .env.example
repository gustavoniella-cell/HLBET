# Copie para .env e preencha. NUNCA comite o .env de verdade.

# String de conexão do Postgres (no deploy, use a do Supabase)
DATABASE_URL="postgresql://USUARIO:SENHA@HOST:5432/postgres?sslmode=require"

# Frase aleatória longa para assinar a sessão de login
SESSION_SECRET="troque-por-uma-frase-bem-aleatoria-e-longa"

# E-mail que terá acesso ao painel de admin
ADMIN_EMAIL="seu-email@exemplo.com"
